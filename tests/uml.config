# UML kernel config fragment for FTDI driver testing
#
# Applied on top of `make ARCH=um defconfig` to enable the subsystems
# needed by the FTDI modules and USB/IP virtual host controller.

# UML PCI/IOMEM emulation - MUST come first to enable HAS_IOMEM
# This enables INDIRECT_IOMEM which disables NO_IOMEM, allowing USB support
CONFIG_UML_PCI_OVER_VFIO=y

# USB/IP client (virtual host controller) - requires HAS_IOMEM from above
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USBIP_CORE=m
CONFIG_USBIP_VHCI_HCD=m

# Networking (localhost only, for USB/IP transport)
CONFIG_NET=y
CONFIG_INET=y

# Subsystems needed by FTDI child drivers
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_SPIDEV=y
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_GPIOLIB=y
CONFIG_GPIOLIB_IRQCHIP=y

# MFD_CORE is selected by MFD_AAT2870_CORE (simple I2C-based MFD driver)
CONFIG_MFD_AAT2870_CORE=y

# Initramfs and virtual filesystems
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# UML-specific
CONFIG_STDERR_CONSOLE=y
CONFIG_PRINTK=y
